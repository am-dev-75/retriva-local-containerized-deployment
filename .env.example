# -----------------------------------------------------------------------------
# Retriva local containerized deployment
# Copy this file to .env and edit it.
# -----------------------------------------------------------------------------

# --- Repository paths, relative to this deployment folder ---
RETRIVA_CORE_DIR=../retriva-core
RETRIVA_GATEWAY_DIR=../retriva-gateway
RETRIVA_WEBUI_DIR=../retriva-webui
RETRIVA_MEDIAWIKI_CONNECTOR_DIR=../retriva-mediawiki-connector

# --- Images ---
QDRANT_IMAGE=qdrant/qdrant:latest
TIKA_IMAGE=apache/tika:latest-full
RETRIVA_CORE_IMAGE=retriva-core:local
RETRIVA_GATEWAY_IMAGE=retriva-gateway:local
RETRIVA_WEBUI_IMAGE=retriva-webui:local
RETRIVA_MEDIAWIKI_CONNECTOR_IMAGE=retriva-mediawiki-connector:local

# --- Host ports ---
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
TIKA_BIND_ADDR=127.0.0.1
TIKA_PORT=9998
CORE_PORT=8001
GATEWAY_PORT=8002
WEBUI_PORT=5173

# --- OpenRouter / OpenAI-compatible provider ---
OPENROUTER_API_KEY=replace-me
OPENAI_API_BASE=https://openrouter.ai/api/v1
OPENAI_BASE_URL=https://openrouter.ai/api/v1
LLM_PROVIDER_BASE_URL=https://openrouter.ai/api/v1
CHAT_MODEL=qwen/qwen3.5-27b
EMBEDDING_MODEL=baai/bge-m3

# --- Core/Gateway wiring ---
QDRANT_URL=http://qdrant:6333
TIKA_URL=http://tika:9998
RETRIVA_CORE_BASE_URL=http://retriva-core:8001
CORE_BASE_URL=http://retriva-core:8001
GATEWAY_BASE_URL=http://retriva-gateway:8002
RETRIVA_GATEWAY_BASE_URL=http://retriva-gateway:8002
VITE_RETRIVA_GATEWAY_BASE_URL=http://localhost:8002

# --- Dynamic ingestion / connectors ---
DYNAMIC_INGESTION_ENABLED=true
CONNECTOR_SERVICE_TOKEN=local-dev-service-token-change-me
MEDIAWIKI_API_URL=https://your.mediawiki.example/api.php
MEDIAWIKI_AUTH_MODE=none
MEDIAWIKI_USERNAME=
MEDIAWIKI_BOT_PASSWORD=
MEDIAWIKI_SOURCE_ID=src_local_mediawiki
MEDIAWIKI_TARGET_KB_ID=default
MEDIAWIKI_CONNECTOR_COMMAND=sleep infinity

# --- Logging / debugging ---
ENABLE_INTERNAL_PROFILER=true
CORE_LOG_LEVEL=INFO
GATEWAY_LOG_LEVEL=INFO
QDRANT_TELEMETRY_DISABLED=true
