# -----------------------------------------------------------------------------
# Retriva local containerized deployment
# Copy this file to .env and edit it.
# -----------------------------------------------------------------------------

# --- Project Configuration ---
# Change this to tag your build/deployment (e.g. customer-a, customer-b)
COMPOSE_PROJECT_NAME=retriva-local

# --- Repository paths, relative to this deployment folder ---
RETRIVA_CORE_DIR=../retriva-core
RETRIVA_GATEWAY_DIR=../retriva-gateway
RETRIVA_WEBUI_DIR=../retriva-webui
RETRIVA_MEDIAWIKI_CONNECTOR_DIR=../retriva-mediawiki-connector

# --- Images ---
QDRANT_IMAGE=qdrant/qdrant:latest
TIKA_IMAGE=apache/tika:latest-full
RETRIVA_CORE_IMAGE=retriva-core:local
RETRIVA_GATEWAY_IMAGE=retriva-gateway:local
RETRIVA_WEBUI_IMAGE=retriva-webui:local
RETRIVA_MEDIAWIKI_CONNECTOR_IMAGE=retriva-mediawiki-connector:local
WHISPER_IMAGE=ghcr.io/ggerganov/whisper.cpp:main

# --- Host ports ---
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
TIKA_BIND_ADDR=127.0.0.1
TIKA_PORT=9998
INGESTION_PORT=8000
CORE_PORT=8001
GATEWAY_PORT=8002
WEBUI_PORT=5173
WHISPER_PORT=8100

# --- LLM / embedding / vision provider (OpenAI-compatible) -------------------
# Retriva uses ONE API key, fanned out internally to every purpose
# (embeddings, vision, chat, rerank).
OPENAI_PROVIDER_API_KEY=replace-me

# Single knob to redirect ALL traffic to a different OpenAI-compatible
# provider (e.g. a local vLLM/Ollama server). Must include the /v1 suffix.
# Defaults to OpenRouter. The per-purpose *_BASE_URL vars below inherit this
# value unless explicitly overridden.
LLM_PROVIDER_BASE_URL=https://openrouter.ai/api/v1

# Optional PER-PURPOSE base-URL overrides. Leave commented to inherit
# LLM_PROVIDER_BASE_URL above. Use these to split traffic across providers,
# e.g. local embeddings but hosted chat/vision.
#EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
#VISUAL_BASE_URL=https://openrouter.ai/api/v1
#CHAT_BASE_URL=https://openrouter.ai/api/v1
#RETRIEVAL_RERANK_BASE_URL=https://openrouter.ai/api/v1

# Models per purpose.
CHAT_MODEL=qwen/qwen3.5-27b
EMBEDDING_MODEL=baai/bge-m3
VISUAL_MODEL=qwen/qwen3-vl-32b-instruct

# --- Core/Gateway wiring ---
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_NAME=retriva_chunks
TIKA_SERVER_URL=http://tika:9998
RETRIVA_CORE_INGESTION_URL=http://retriva-ingestion:8000
RETRIVA_CORE_CHAT_URL=http://retriva-core:8001
GATEWAY_BASE_URL=http://retriva-gateway:8002
RETRIVA_GATEWAY_BASE_URL=http://retriva-gateway:8002
VITE_RETRIVA_GATEWAY_BASE_URL=http://localhost:8002

# --- Dynamic ingestion / connectors ---
DYNAMIC_INGESTION_ENABLED=true
GATEWAY_INTERNAL_SERVICE_TOKEN=local-dev-service-token-change-me
MEDIAWIKI_CONNECTOR_API_URL=https://your.mediawiki.example/api.php
MEDIAWIKI_CONNECTOR_AUTH_MODE=none
MEDIAWIKI_CONNECTOR_USERNAME=
MEDIAWIKI_CONNECTOR_BOT_PASSWORD=
MEDIAWIKI_CONNECTOR_SOURCE_ID=src_local_mediawiki
MEDIAWIKI_CONNECTOR_TARGET_KB_ID=default
MEDIAWIKI_CONNECTOR_COMMAND=sleep infinity

# --- Logging / debugging ---
ENABLE_INTERNAL_PROFILER=true
CORE_LOG_LEVEL=INFO
GATEWAY_LOG_LEVEL=INFO
QDRANT_TELEMETRY_DISABLED=true

# --- Speech-to-Text (Whisper) ---
STT_ENABLED=true
WHISPER_SERVER_URL=http://whisper:${WHISPER_PORT}/inference
WHISPER_MODEL=ggml-base.en.bin
VITE_SPEECH_INPUT_MODE=gateway
VITE_RETRIVA_ENABLE_VOICE_INPUT=true

# Extra attempts on 429 / connection / timeout / 5xx errors (0 = no retries).
VISUAL_MAX_RETRIES=5
# Initial backoff in seconds; doubled each retry (with jitter), capped below.
VISUAL_RETRY_BASE_DELAY=2.0
# Ceiling for a single backoff sleep, in seconds.
VISUAL_RETRY_MAX_DELAY=60.0
# Seconds to sleep between successive image descriptions (0 = no pacing).
# Raise this (e.g. 1.5) if you keep hitting upstream rate limits.
VISUAL_INTER_CALL_DELAY=1.5
